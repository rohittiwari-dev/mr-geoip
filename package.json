{
  "name": "mr-geoip",
  "version": "0.1.2",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "description": "A framework-agnostic IP geolocation with LRU caching and custom data persistence.",
  "license": "MIT",
  "author": "Rohit",
  "scripts": {
    "build": "tsup && tsc",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "update:ipdb": "bun run scripts/update-ip-dbs.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"import('fs').then(fs => { if (fs.existsSync('./dist/postinstall.js')) { import('./dist/postinstall.js'); } })\""
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "mr-geoip-update": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "DOCUMENTATION.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "geoip",
    "geolocation",
    "ip",
    "maxmind",
    "mmdb",
    "lru-cache",
    "ip-lookup",
    "serverless",
    "typescript",
    "bun",
    "deno"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rohittiwari-dev/mr-geoip.git"
  },
  "bugs": {
    "url": "https://github.com/rohittiwari-dev/mr-geoip/issues"
  },
  "homepage": "https://github.com/rohittiwari-dev/mr-geoip#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "mmdb-lib": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "lru-cache": "^11.5.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
